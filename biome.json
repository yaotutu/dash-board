{
  "$schema": "https://biomejs.dev/schemas/1.5.3/schema.json",
  "organizeImports": {
    "enabled": true
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "suspicious": {
        "noExplicitAny": "warn",
        "noCompareNegZero": "warn"
      },
      "correctness": {
        "noConstantCondition": "off"
      }
    }
  },
  "formatter": {
    "indentStyle": "space",
    "indentSize": 4
  }
}
